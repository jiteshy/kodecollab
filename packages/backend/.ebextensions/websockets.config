option_settings:
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckInterval: 10
    HealthCheckTimeout: 5
    HealthyThresholdCount: 3
    UnhealthyThresholdCount: 5
    Port: 443
    Protocol: HTTPS
    MatcherHTTPCode: 200
  
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

  aws:elasticbeanstalk:application:environment:
    AWS_ELB_IDLE_TIMEOUT: '3600'

  aws:elasticbeanstalk:environment:
    LoadBalancerType: application

  aws:elasticbeanstalk:loadbalancer:
    Stickiness: true
    StickinessPolicy: lb_cookie
    StickinessLBCookieDuration: '86400'
    ListenerProtocol: HTTPS
    ListenerPort: 443

  aws:elbv2:listener:443:
    Protocol: HTTPS
    SSLCertificateArns: arn:aws:acm:us-east-2:885820157461:certificate/8f4eba73-5587-4a84-9d8b-aafeba4b3a3f
    DefaultProcess: default
    Rules: default
    SSLPolicy: ELBSecurityPolicy-TLS-1-2-2017-01

  aws:elbv2:listener:80:
    Protocol: HTTP
    DefaultProcess: default
    Rules: default
    ListenerEnabled: true